cask "{{CASK_NAME}}" do
  version "{{VERSION}}"
  sha256 "{{SHA256}}"

  url "https://example.com/{{SLUG}}/download/#{version}/{{TARGET}}"
  name "{{APP_NAME}}"
  desc "{{DESCRIPTION}}"
  homepage "{{HOMEPAGE}}"

  livecheck do
    url "https://example.com/{{SLUG}}"
    strategy :json do |json|
      json["latest"]
    end
  end

  depends_on macos: ">= :ventura"

  app "{{APP_NAME}}.app"

  zap trash: [
    "~/Library/Containers/{{BUNDLE_ID}}",
    "~/Library/Application Scripts/{{BUNDLE_ID}}",
  ]
end
