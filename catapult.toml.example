# catapult.toml — release configuration for a Swift macOS app.
# Copy to <app-repo>/catapult.toml and edit for each app.

[app]
name        = "MyApp"                       # display name, .app bundle, executable
slug        = "myapp"                       # lowercase, URL/filename segment
bundle_id   = "com.example.myapp"
team_id     = "556XHQJK3G"
developer   = "Douglas Lassance"           # signing identity name
homepage    = "https://example.com/myapp"
description = "Short tagline"              # used in Homebrew cask `desc`
category    = "public.app-category.productivity"
min_macos   = "13.0"

[build]
kind          = "swift"                    # "swift" (default) or "tauri"
arch          = "arm64"                    # passed to `swift build --arch`
target_triple = "aarch64-apple-darwin"     # used in DMG filename + URLs
swift_target  = "App"                      # SPM target name; resource bundle is "${name}_${swift_target}.bundle"
# Optional overrides (defaults shown):
# executable            = "${name}"        # binary name in .build/release; set if it differs from app.name
# icon                  = "Sources/App/Resources/AppIcon.png"
# icon_command          = "swift render_icon.swift build/icon.iconset && iconutil -c icns build/icon.iconset -o build/AppIcon.icns"
# assets                = "Sources/App/Resources/Assets.xcassets"
# entitlements_direct   = "${name}.entitlements"
# entitlements_appstore = "${name}-appstore.entitlements"
# provisioning_profile  = "${name}.provisionprofile"   # filename in ~/Library/MobileDevice/Provisioning Profiles/

# For kind = "tauri", instead of swift_target use:
# package_manager     = "bun"              # "bun", "pnpm", "yarn", or "npm"
# tauri_dir           = "src-tauri"        # default
# frontend_build      = "bun run build"    # default = "${package_manager} run build"

# --- Optional channels --- presence of each section enables that channel.

[sparkle]                                  # embed Sparkle in direct build + sign DMG
# Requires `import Sparkle` in Package.swift and SPUStandardUpdaterController
# wired in the app. Without that dependency the build script warns and skips
# embedding — the [sparkle] section alone doesn't pull Sparkle in.
feed_url = "https://example.com/myapp/myapp.xml"

[dmg]                                      # always on for direct builds, but lets you set the volume name
volume_name = "MyApp"

[s3]                                       # upload DMG / appcast / KV to S3-compatible storage (Cloudflare R2, AWS S3, etc.)
bucket_prefix         = "myapp"             # objects land at s3://${bucket}/${bucket_prefix}/
appcast_filename      = "myapp.xml"
download_url_template = "https://example.com/myapp/download/{version}/{target}"
# kv_key = "myapp"                          # defaults to slug

[homebrew]                                 # push a cask update to a Homebrew tap
cask_name = "myapp"
# cask_template = "cask.rb"                # path relative to app repo (default)

[appstore]                                 # build .pkg + upload to App Store Connect
non_exempt_encryption = false

# Two modes for the Info.plist:
#
# A) Generated (default) — built from catapult.toml fields. List usage
#    descriptions and any extra string/bool/int keys here.
[plist.usage_descriptions]
NSDesktopFolderUsageDescription   = "MyApp needs access to your Desktop folder."
NSDocumentsFolderUsageDescription = "MyApp needs access to your Documents folder."

# [plist.extras]
# LSUIElement = true
#
# B) Passthrough — point at an existing Info.plist in the app repo. Trigger
#    only injects CFBundleShortVersionString / CFBundleVersion / Sparkle keys
#    / ITSAppUsesNonExemptEncryption and preserves everything else (document
#    types, UTI declarations, custom keys). Use this when the app has
#    structures the generator can't produce.
#
# [plist]
# template = "Info.plist"
